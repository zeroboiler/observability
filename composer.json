{
    "name": "zeroboiler/observability",
    "description": "OpenTelemetry-based observability for Laravel: traces, metrics, logs, and health checks",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "observability",
        "opentelemetry",
        "otel",
        "tracing",
        "metrics",
        "health-checks",
        "laravel",
        "zeroboiler"
    ],
    "authors": [
        {
            "name": "AI Kankim",
            "email": "ai@zeroboiler.dev"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/redis": "^13.0",
        "illuminate/mail": "^13.0",
        "illuminate/cache": "^13.0",
        "open-telemetry/sdk": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "pestphp/pest": "^3.0",
        "rector/rector": "^2.0",
        "fakerphp/faker": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "ZeroBoiler\\Observability\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZeroBoiler\\Observability\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZeroBoiler\\Observability\\ObservabilityServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage",
        "lint": "pint",
        "lint:fix": "pint",
        "analyse": "phpstan analyse",
        "rector": "rector process"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}